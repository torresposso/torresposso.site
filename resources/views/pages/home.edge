@layout()
  <!-- Hero Section -->
  <div class="hero min-h-[60vh] bg-gradient-to-br from-indigo-900 via-purple-900 to-slate-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <div class="hero-content text-center z-10">
      <div class="max-w-2xl">
        <div class="badge badge-primary badge-outline mb-4 px-4 py-3 font-semibold tracking-wide">ASTROLABIO PROJECT</div>
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-cyan-400 via-teal-300 to-indigo-400 bg-clip-text text-transparent mb-6">
          torresposso.site
        </h1>
        <p class="text-xl text-slate-300 mb-8 font-light">
          Construyendo la próxima generación de plataformas web con integraciones de Inteligencia Artificial y metodología de desarrollo guiada por especificaciones (SDD).
        </p>
        <div class="flex justify-center gap-4">
          <button class="btn btn-primary shadow-lg shadow-primary/20">Ver Servicios</button>
          <button class="btn btn-outline btn-secondary">Contactame</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Services Grid Section -->
  <div class="py-20 px-6 max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">Servicios & Metodología</h2>
      <p class="text-slate-500 max-w-lg mx-auto">Soluciones robustas para llevar tu producto desde la especificación abstracta hasta un sistema en producción.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Card 1 -->
      <div class="card bg-base-100 shadow-xl border border-slate-100 hover:shadow-2xl transition-all duration-300">
        <div class="card-body">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary text-2xl font-bold mb-4">
            🌐
          </div>
          <h3 class="card-title text-slate-800 text-xl font-bold">Plataformas Web</h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Desarrollo de aplicaciones robustas, escalables y responsivas adaptadas a las necesidades reales de tu negocio.
          </p>
          <div class="card-actions justify-end mt-4">
            <div class="badge badge-ghost">AdonisJS</div>
            <div class="badge badge-ghost">Vite</div>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="card bg-base-100 shadow-xl border border-slate-100 hover:shadow-2xl transition-all duration-300">
        <div class="card-body">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary text-2xl font-bold mb-4">
            🤖
          </div>
          <h3 class="card-title text-slate-800 text-xl font-bold">Integración con IA</h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Agentes autónomos, flujos de trabajo inteligentes y sistemas RAG para potenciar el valor de tus datos y procesos.
          </p>
          <div class="card-actions justify-end mt-4">
            <div class="badge badge-ghost">MCP</div>
            <div class="badge badge-ghost">LLMs</div>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="card bg-base-100 shadow-xl border border-slate-100 hover:shadow-2xl transition-all duration-300">
        <div class="card-body">
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center text-accent text-2xl font-bold mb-4">
            📐
          </div>
          <h3 class="card-title text-slate-800 text-xl font-bold">Metodología SDD</h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Spec-Driven Development. Diseñamos con especificaciones claras antes de tocar código para asegurar la máxima calidad.
          </p>
          <div class="card-actions justify-end mt-4">
            <div class="badge badge-ghost">TDD</div>
            <div class="badge badge-ghost">OpenSpec</div>
          </div>
        </div>
      </div>
    </div>
  </div>
@end
